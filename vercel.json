{
  "rewrites": [
    { "source": "/templates", "destination": "/templates.html" },
    { "source": "/template-saas", "destination": "/template-saas.html" },
    { "source": "/template-ecommerce", "destination": "/template-ecommerce.html" },
    { "source": "/template-finance", "destination": "/template-finance.html" },
    { "source": "/template-wellness", "destination": "/template-wellness.html" },
    { "source": "/template-crm", "destination": "/template-crm.html" },
    { "source": "/template-sports", "destination": "/template-sports.html" },
    { "source": "/template-industrial", "destination": "/template-industrial.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "DENY" },
        { "key": "X-XSS-Protection",          "value": "1; mode=block" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",        "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Content-Security-Policy",   "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://*.make.com; frame-ancestors 'none';" }
      ]
    }
  ]
}
